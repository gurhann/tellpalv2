# Copy this file to ops/railway/production.env and fill in the real values.
# Do not commit ops/railway/production.env.

TELLPAL_ADMIN_JWT_SECRET=replace-with-at-least-32-bytes
TELLPAL_ADMIN_BOOTSTRAP_USERNAME=
TELLPAL_ADMIN_BOOTSTRAP_PASSWORD=
TELLPAL_ADMIN_BOOTSTRAP_ROLE_CODE=ADMIN

TELLPAL_FIREBASE_PROJECT_ID=replace-with-firebase-project-id
TELLPAL_ASSET_STORAGE_FIREBASE_BUCKET_NAME=replace-with-firebase-storage-bucket

# Preferred: point to the Firebase service account JSON file and the deploy script will base64-encode it.
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=C:\path\to\firebase-service-account.json

# Alternative: provide the already base64-encoded JSON directly.
FIREBASE_SERVICE_ACCOUNT_JSON_B64=

# Optional for now. When blank, the app starts but RevenueCat webhooks remain unauthorized.
TELLPAL_REVENUECAT_AUTHORIZATION_HEADER=
